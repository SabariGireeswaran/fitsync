<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="16"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.fitsync.controller.LoginController"
      style="-fx-background-color: #F8F9FA;">

    <padding>
        <Insets top="80" right="320" bottom="80" left="320"/>
    </padding>

    <Label text="FitSync" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #4A90D9;"/>
    <Label text="Sign in to your account" style="-fx-font-size: 14px; -fx-text-fill: #718096;"/>

    <Label text="" minHeight="10"/>

    <Label text="Email" style="-fx-font-weight: bold;"/>
    <TextField fx:id="emailField" promptText="Enter your email"
               maxWidth="400"/>

    <Label text="Password" style="-fx-font-weight: bold;"/>
    <PasswordField fx:id="passwordField" promptText="Enter your password"
                   maxWidth="400"/>

    <Label fx:id="errorLabel" text="" style="-fx-text-fill: #E53E3E; -fx-font-size: 13px;"/>

    <Button fx:id="loginButton" text="Login"
            onAction="#handleLogin"
            maxWidth="400"
            style="-fx-background-color: #4A90D9; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20 10 20; -fx-background-radius: 6; -fx-cursor: hand;"/>

    <Hyperlink text="Don't have an account? Register"
               onAction="#handleRegister"
               style="-fx-text-fill: #4A90D9;"/>

</VBox>