<?xml version ="1.0" encoding ="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<BorderPane xmlns="http://javafx.com/javafx" 
            xmln:fx="http://javafx.com/fxml"
            fx:controller="com.fitsync.controller.DashboardController"
            style="-fx-background-color: #F8F9FA;">

    <!--sIDEBAR -->
    <left>
        <VBox spacing="0"
            style="-fx-background-color: #2D3748; -fx-min-width: 220px;">
            <padding>
                <Insets top="30" right="0" bottom="30" left="0"/>
            </padding>
            <Label text="FitSync"
            style="-fx-text-fill: white; -fx-font-size: 22px;
                -fx-font-weight: bold; -fx-padding: 0 20 20 20;"/>
            
            <Button fx:id="btnDashboard" text="Dashboard"
                    onAction="#showDashboard" maxwidth="220"
                    style="-fx-background-color: #4A90D9; -fx-text-fill: white;
                    -fx-font-size: 14px; -fx-padding: 12 20 12 20;
                    -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            
            <Button fx:id="btnBmi" text="BMI Calculator"
                    onAction="#showBmi" maxwidth="220"
                    style="-fx-background-color: transparent; -fx-text-fill: #A0AEC0;
                    -fx-font-size: 14px; -fx-padding: 12 20 12 20;
                    -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            
            <Button fx:id="btnWorkout" text="Workout Log"
                    onAction="#showWorkout" maxWidth="220"
                    style="-fx-background-color: transparent; -fx-text-fill: #A0AEC0;
                    -fx-font-size: 14px; -fx-padding: 12 20 12 20;
                    -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
            
            <Button fx:id="btnLogout" text="Logout"
                    onAction="#handleLogout" maxWidth="220"
                    style="-fx-background-color: transparent; -fx-text-fill: #FC8181;
                        -fx-font-size: 14px; -fx-padding: 12 20 12 20;
                        -fx-alignment: CENTER_LEFT; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <!-- Main Content -->
    <center>
        <VBox spacing="20">
            <padding>
                <Insets top="40" right="40" bottom="40" left="40"/>
            </padding>
            
            <Label fx:id="welcomeLabel" text="Welcome back!"
                style="-fx-font-size: 28px; -fx-font-weight: bold;
                -fx-text-fill: #2D3748;"/>
            <Label text="Here is your wellness summary"
                style="-fx-font-size: 14px; -fx-text-fill: #718096;"/>
            
            <!-- Stats Row -->
            <HBox spacing="20">
                
                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                            -fx-effect: dropshadow(gaussian, rgba(0,0,0,0,0.08), 8, 0, 0, 2);
                            -fx-padding: 24; -fx-min-width: 180px;">
                    <Label text="YOUR BMI"
                            style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                    <Label fx:id="bmiLabel" text="--"
                            style="-fx-font-size: 32px; -fx-font-weight: bold;
                            -fx-text-fill: #4A90D9;"/>
                    <label fx:id="bmiCategoryLabel" text="Not calculated"
                            style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>
                        
                </VBox>

                <VBox style="-fx-background-color: white; -fx-background-radius: 10;
                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8,0,0,2);
                        -fx-padding: 24; -fx-min-width: 180px;">
                    <Label text="CURRENT WEIGHT"
                            style="-fx-font-size: 12px; -fx-text-fill: #718096"/>
                    <Label fx:id="weightLabel" text="-- kg"
                            style="-fx-font-size: 32px; -fx-font-weight: bold;
                            -fx-text-fill: #DD6B20;"/>
                    <Label text="Last recorded"
                            style="-fx-font-size: 13px; -fx-text-full: #718096;"/>
                </VBox>
            </HBox>

        </VBox>
    </center>
</BorderPane>