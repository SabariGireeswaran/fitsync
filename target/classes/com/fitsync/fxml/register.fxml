<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="12"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.fitsync.controller.RegisterController"
      style="-fx-background-color: #F8F9FA;">

    <padding>
        <Insets top="50" right="280" bottom="50" left="280"/>
    </padding>

    <Label text="FitSync" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #4A90D9;"/>
    <Label text="Create your account" style="-fx-font-size: 14px; -fx-text-fill: #718096;"/>

    <Label text="" minHeight="8"/>

    <Label text="Full Name" style="-fx-font-weight: bold;"/>
    <TextField fx:id="nameField" promptText="Enter your full name" maxWidth="400"/>

    <Label text="Email" style="-fx-font-weight: bold;"/>
    <TextField fx:id="emailField" promptText="Enter your email" maxWidth="400"/>

    <Label text="Password" style="-fx-font-weight: bold;"/>
    <PasswordField fx:id="passwordField" promptText="Create a password" maxWidth="400"/>

    <Label text="Age" style="-fx-font-weight: bold;"/>
    <TextField fx:id="ageField" promptText="Enter your age" maxWidth="400"/>

    <Label text="Gender" style="-fx-font-weight: bold;"/>
    <ComboBox fx:id="genderCombo" promptText="Select gender" maxWidth="400"/>

    <Label text="Height (cm)" style="-fx-font-weight: bold;"/>
    <TextField fx:id="heightField" promptText="e.g. 175" maxWidth="400"/>

    <Label text="Weight (kg)" style="-fx-font-weight: bold;"/>
    <TextField fx:id="weightField" promptText="e.g. 70" maxWidth="400"/>

    <Label fx:id="errorLabel" text="" style="-fx-text-fill: #E53E3E; -fx-font-size: 13px;"/>

    <Button text="Create Account"
            onAction="#handleRegister"
            maxWidth="400"
            style="-fx-background-color: #4A90D9; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20 10 20; -fx-background-radius: 6; -fx-cursor: hand;"/>

    <Hyperlink text="Already have an account? Login"
               onAction="#handleLogin"
               style="-fx-text-fill: #4A90D9;"/>

</VBox>